{
  "name": "simplecafe",
  "version": "1.0.0",
  "description": "Simple Cafe Website with Integrated POS, KDS, CMS, and Inventory",
  "scripts": {
    "dev": "wrangler pages dev public",
    "deploy": "wrangler pages deploy public",
    "build": "tsc",
    "db:migrate:local": "wrangler d1 execute simple-cafe-db --local --file=./schema.sql",
    "db:migrate:remote": "wrangler d1 execute simple-cafe-db --remote --file=./schema.sql"
  },
  "dependencies": {
    "@prisma/adapter-d1": "^5.10.2",
    "@prisma/client": "^5.10.2",
    "hono": "^4.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240320.1",
    "@types/node": "^20.11.30",
    "typescript": "^5.4.3",
    "wrangler": "^4.76.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
